              "mode": "raw",
              "raw": "{\n  \"key\": \"plans_filter\",\n  \"type\": \"select_filter\",\n  \"active\": true,\n  \"sort\": 2,\n  \"fields\": [\n    {\n      \"key\": \"title\",\n      \"type\": \"object\",\n      \"label\": {\n        \"en\": \"Title\",\n        \"ar\": \"العنوان\"\n      },\n      \"value\": {\n        \"en\": \"Find your meal plan\",\n        \"ar\": \"اختر خطتك الغذائية\"\n      }\n    },\n    {\n      \"key\": \"default_plan\",\n      \"type\": \"string\",\n      \"label\": {\n        \"en\": \"Default Plan\",\n        \"ar\": \"الخطة الافتراضية\"\n      },\n      \"value\": \"balanced\"\n    },\n    {\n      \"key\": \"options\",\n      \"type\": \"array\",\n      \"label\": {\n        \"en\": \"Options\",\n        \"ar\": \"الخيارات\"\n      },\n      \"value\": [\n        {\n          \"key\": \"balanced\",\n          \"label\": {\n            \"en\": \"Balanced\",\n            \"ar\": \"متوازن\"\n          }\n        },\n        {\n          \"key\": \"low_carb\",\n          \"label\": {\n            \"en\": \"Low Carb\",\n            \"ar\": \"قليل الكربوهيدرات\"\n          }\n        },\n        {\n          \"key\": \"high_protein\",\n          \"label\": {\n            \"en\": \"High Protein\",\n            \"ar\": \"عالي البروتين\"\n          }\n        }\n      ]\n    }\n  ],\n  \"data\": {\n    \"source\": \"diet_plans\"\n  },\n  \"locales\": [\n    {\n      \"locale\": \"en\",\n      \"name\": \"Plans Filter\",\n      \"description\": \"Select input widget for plans\"\n    },\n    {\n      \"locale\": \"ar\",\n      \"name\": \"فلتر الخطط\",\n      \"description\": \"ودجت اختيار الخطط\"\n    }\n  ]\n}"
            },
