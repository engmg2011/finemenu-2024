            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"hero\",\n  \"type\": \"hero\",\n  \"active\": true,\n  \"sort\": 1,\n  \"fields\": [\n    {\n      \"key\": \"title\",\n      \"type\": \"object\",\n      \"label\": {\n        \"en\": \"Title\",\n        \"ar\": \"العنوان\"\n      },\n      \"value\": {\n        \"en\": \"Fresh meals delivered daily\",\n        \"ar\": \"وجبات طازجة يوميا\"\n      }\n    },\n    {\n      \"key\": \"subtitle\",\n      \"type\": \"object\",\n      \"label\": {\n        \"en\": \"Subtitle\",\n        \"ar\": \"العنوان الفرعي\"\n      },\n      \"value\": {\n        \"en\": \"Choose a plan that fits your routine.\",\n        \"ar\": \"اختر خطة تناسب يومك.\"\n      }\n    },\n    {\n      \"key\": \"button_text\",\n      \"type\": \"object\",\n      \"label\": {\n        \"en\": \"Button Text\",\n        \"ar\": \"نص الزر\"\n      },\n      \"value\": {\n        \"en\": \"Start now\",\n        \"ar\": \"ابدأ الآن\"\n      }\n    },\n    {\n      \"key\": \"image_url\",\n      \"type\": \"string\",\n      \"label\": {\n        \"en\": \"Image URL\",\n        \"ar\": \"رابط الصورة\"\n      },\n      \"value\": \"https://example.com/hero.jpg\"\n    },\n    {\n      \"key\": \"display_order\",\n      \"type\": \"numeric\",\n      \"label\": {\n        \"en\": \"Display Order\",\n        \"ar\": \"ترتيب العرض\"\n      },\n      \"value\": 1\n    }\n  ],\n  \"data\": {\n    \"variant\": \"image-right\"\n  },\n  \"locales\": [\n    {\n      \"locale\": \"en\",\n      \"name\": \"Hero\",\n      \"description\": \"Top section\"\n    },\n    {\n      \"locale\": \"ar\",\n      \"name\": \"البطل\",\n      \"description\": \"القسم العلوي\"\n    }\n  ]\n}"
